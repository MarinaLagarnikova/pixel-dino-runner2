{
  "name": "pixel-dino-runner",
  "version": "1.0.0",
  "description": "Pixel Dino Runner — browser game",
  "type": "module",
  "scripts": {
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --passWithNoTests",
    "lint": "eslint .",
    "cpd": "jscpd .",
    "cpd:diff": "bash scripts/cpd-diff.sh",
    "cpd:diff-each": "bash scripts/cpd-diff-each.sh",
    "validate": "npm run lint && npm run cpd && npm run cpd:diff && npm run cpd:diff-each && npm test"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/jest": "^30.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.1.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jscpd": "^4.0.8"
  }
}
